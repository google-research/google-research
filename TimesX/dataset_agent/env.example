# Google Custom Search credentials used by the search pipeline.
CUSTOMSEARCH_API_KEY=YOUR_GOOGLE_CUSTOM_SEARCH_API_KEY
CUSTOMSEARCH_CX_KEY=YOUR_GOOGLE_CUSTOM_SEARCH_ENGINE_ID

# Gemini API key used by LLM stages.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Optional: Gemini search timeout settings in milliseconds.
GEMINI_SEARCH_HTTP_TIMEOUT_MS=60000
GEMINI_RECALIBRATION_HTTP_TIMEOUT_MS=60000

# Optional: Weather data source
WEATHER_API_KEY=

# Optional: Oxylabs proxy for Google Trends fallback on rate limiting
OXYLABS_USERNAME_BASE=
OXYLABS_PASSWORD=
OXYLABS_PROXY_HOST=
OXYLABS_PROXY_PORT=8000
OXYLABS_PROXY_COUNTRY=US
